# --- Frontend Environment Variables (Exposed to Bundle) ---
# Only variables prefixed with VITE_ are available in the frontend.
# Do NOT put any secrets, passwords, or private keys here.

VITE_MAINTENANCE_MODE=false


# --- Backend Environment Variables (Vercel Serverless Functions) ---
# These are ONLY available in the api/ directory and never exposed to the client.

# Maintenance Bypass Secret (Minimum 12 characters recommended)
MAINTENANCE_BYPASS_SECRET=your_long_secure_bypass_secret_here

# EmailJS Configuration (Backend Proxy)
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key
